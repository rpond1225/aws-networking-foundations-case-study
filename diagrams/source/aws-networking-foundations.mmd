graph TB

    Internet["Internet / Users"]
    TrustedAdmin["Trusted Administrator<br/>Configured CIDR"]

    subgraph Account["AWS Account"]

        subgraph Region["Region: us-east-1"]

            subgraph VPC["VPC: 10.10.0.0/16"]

                IGW["Internet Gateway"]

                subgraph AZ["Availability Zone: us-east-1a"]

                    subgraph PublicSubnet["Public Subnet: 10.10.1.0/24"]

                        PublicRT["Public Route Table<br/>10.10.0.0/16 → local<br/>0.0.0.0/0 → Internet Gateway"]

                        PublicSG["Public Web Security Group<br/>Inbound: HTTP 80 from Internet<br/>Inbound: HTTPS 443 from Internet<br/>Inbound: SSH 22 from Trusted CIDR<br/>Outbound: All"]

                    end

                    subgraph PrivateSubnet["Private Subnet: 10.10.11.0/24"]

                        PrivateRT["Private Route Table<br/>10.10.0.0/16 → local<br/>No Internet default route"]

                        PrivateSG["Private Application Security Group<br/>Inbound: TCP 8080 from Public Web SG<br/>Outbound: All"]

                    end

                end

            end

        end

    end

    Internet --> IGW
    PublicRT -->|"0.0.0.0/0"| IGW

    Internet -.->|"HTTP 80 / HTTPS 443 allowed"| PublicSG
    TrustedAdmin -.->|"SSH 22 allowed"| PublicSG
    PublicSG -.->|"TCP 8080 allowed"| PrivateSG

    classDef account stroke:#818cf8,fill:#eef2ff
    classDef region stroke:#818cf8,fill:#eef2ff
    classDef vpc stroke:#2dd4bf,fill:#f0fdfa
    classDef az stroke:#38bdf8,fill:#f0f9ff
    classDef subnet stroke:#22d3ee,fill:#ecfeff
    classDef route stroke:#a78bfa,fill:#faf5ff
    classDef sg stroke:#fb923c,fill:#fff7ed
    classDef resource stroke:#4ade80,fill:#f0fdf4
    classDef external stroke:#f87171,fill:#fef2f2

    class Account account
    class Region region
    class VPC vpc
    class AZ az
    class PublicSubnet,PrivateSubnet subnet
    class PublicRT,PrivateRT route
    class PublicSG,PrivateSG sg
    class IGW resource
    class Internet,TrustedAdmin external